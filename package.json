{
  "name": "git-guis",
  "version": "1.0.0",
  "description": "A tabbed git-gui style desktop app.",
  "main": "dist-electron/electron/main.js",
  "bin": {
    "ggs": "./bin/ggs"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && node scripts/dev-electron.cjs",
    "build": "npm run check && npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "check": "biome check && npm run typecheck",
    "check:fix": "biome check --write",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
